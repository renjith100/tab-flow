{
  "manifest_version": 3,
  "name": "TabFlow",
  "description": "Bring your tab count down — see every tab at a glance, spot stale ones and duplicates, and close the clutter in one click.",
  "version": "2.0.0",
  "homepage_url": "https://github.com/renjith100/tab-flow",
  "action": {
    "default_title": "TabFlow",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Command+Shift+Period",
        "default": "Ctrl+Shift+Period"
      },
      "description": "Open TabFlow"
    }
  },
  "permissions": [
    "tabs",
    "windows",
    "sessions",
    "tabGroups"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}